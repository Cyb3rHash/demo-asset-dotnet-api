# .NET API container environment variables
# Request these to be set in the real .env by the orchestrator/deployment system.

# Port for Kestrel to listen on (used by PreviewManager; demo uses 3010)
PORT=3010

# OPTIONAL (recommended for production):
# Provide a real TLS certificate for Kestrel.
# If not set, the app will attempt to use the ASP.NET Core development certificate.
#
# ASPNETCORE_Kestrel__Certificates__Default__Path=/path/to/cert.pfx
# ASPNETCORE_Kestrel__Certificates__Default__Password=change_me
